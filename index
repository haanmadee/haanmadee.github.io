            font-size: 14px; 
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        
        @keyframes heartbeat {
            0%, 100% { transform: scale(1); }
            10%, 30% { transform: scale(1.08); color: #ffffff; }
            20% { transform: scale(1); }
        }
        .animate-heartbeat {
            animation: heartbeat 2.5s infinite;
            display: inline-block; 
            transform-origin: right center; 
        }

        /* Animasi Floating Lambat & Ringan */
        @keyframes drift {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-6px) rotate(1deg); }
        }
        .animate-floating {
            animation: drift 6s ease-in-out infinite;
        }
        .animate-floating-delay-1 {
            animation: drift 7s ease-in-out infinite;
            animation-delay: 1.5s;
        }
        .animate-floating-delay-2 {
            animation: drift 8s ease-in-out infinite;
            animation-delay: 3s;
        }
        .animate-floating-delay-3 {
            animation: drift 9s ease-in-out infinite;
            animation-delay: 4.5s;
        }

        /* Efek Glow Halus untuk Teks */
        .text-glow {
            text-shadow: 0 0 8px rgba(255, 255, 255, 0.7), 0 0 16px rgba(255, 255, 255, 0.4);
        }

        /* ANIMASI POCKET STYLE BARU (Single Short Rectangular Card) */
        .pocket-card-animate {
            transform: translate(-50%, 20px);
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .pocket-open .pocket-card-animate {
            transform: translate(-50%, -45px);
            opacity: 1 !important;
            pointer-events: auto; 
        }

        /* TAMBAHAN CSS UNTUK TESTIMONI MONOCHROME */
        .testi-card-mono {
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative;
            margin-left: -35px; /* Efek overlap menyamping */
            flex-shrink: 0;
            cursor: pointer;
        }
        .testi-card-mono:first-child {
            margin-left: 0; /* Kartu pertama ga perlu minus margin */
        }
        .testi-card-mono.active-mono {
            transform: scale(1.08) translateY(-5px) !important; 
            z-index: 99 !important; 
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.9), 0 8px 10px -6px rgba(0, 0, 0, 0.7);
        }
        .testi-container-wrapper {
            padding: 15px 25px 30px 25px; 
        }
        .active-mono p.line-clamp-4 {
            -webkit-line-clamp: unset !important; 
        }
    </style>
