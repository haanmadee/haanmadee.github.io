    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Main Banner Slider Logic
            const slider = document.getElementById('banner-slider');
            let autoSlideInterval;

            function startAutoSlide() {
                autoSlideInterval = setInterval(function() {
                    const maxScrollLeft = slider.scrollWidth - slider.clientWidth;
                    if (slider.scrollLeft >= maxScrollLeft - 10) { 
                        slider.scrollTo({ left: 0, behavior: 'smooth' });
                    } else {
                        slider.scrollBy({ left: slider.clientWidth, behavior: 'smooth' });
                    }
                }, 3000); 
            }

            function stopAutoSlide() {
                clearInterval(autoSlideInterval);
            }

            if(slider) {
                startAutoSlide();
                slider.addEventListener('touchstart', stopAutoSlide);
                slider.addEventListener('touchend', startAutoSlide);
                slider.addEventListener('mouseenter', stopAutoSlide);
                slider.addEventListener('mouseleave', startAutoSlide);
            }

            // Product Slider Horizontal Manual Scroll Logic (SHOPEE)
            const flashSaleSlider = document.getElementById('flash-sale-slider');
            const slideNextBtn = document.getElementById('slide-next-btn');

            if (slideNextBtn && flashSaleSlider) {
                slideNextBtn.addEventListener('click', () => {
                    const cardWidth = 157; 
                    const maxScrollLeft = flashSaleSlider.scrollWidth - flashSaleSlider.clientWidth;
                    if (flashSaleSlider.scrollLeft >= maxScrollLeft - 10) {
                        flashSaleSlider.scrollTo({ left: 0, behavior: 'smooth' });
                    } else {
                        flashSaleSlider.scrollBy({ left: cardWidth, behavior: 'smooth' });
                    }
                });
            }

            // Product Slider Horizontal Manual Scroll Logic (TIKTOK)
            const tiktokSlider = document.getElementById('tiktok-slider');
            const slideNextBtnTiktok = document.getElementById('slide-next-btn-tiktok');

            if (slideNextBtnTiktok && tiktokSlider) {
                slideNextBtnTiktok.addEventListener('click', () => {
                    const cardWidth = 157; 
                    const maxScrollLeft = tiktokSlider.scrollWidth - tiktokSlider.clientWidth;
                    if (tiktokSlider.scrollLeft >= maxScrollLeft - 10) {
                        tiktokSlider.scrollTo({ left: 0, behavior: 'smooth' });
                    } else {
                        tiktokSlider.scrollBy({ left: cardWidth, behavior: 'smooth' });
                    }
                });
            }

            // Webinar Auto-Slider Logic
            const webinarSlider = document.getElementById('webinar-slider');
            const webinarDots = document.querySelectorAll('.webinar-dot');
            let currentWebinarSlide = 0;

            if (webinarSlider && webinarDots.length > 0) {
                setInterval(() => {
                    currentWebinarSlide = (currentWebinarSlide + 1) % 3;
                    webinarSlider.style.transform = `translateX(-${currentWebinarSlide * 100}%)`;
                    
                    webinarDots.forEach((dot, index) => {
                        if(index === currentWebinarSlide) {
                            dot.classList.replace('bg-zinc-700', 'bg-white');
                        } else {
                            dot.classList.replace('bg-white', 'bg-zinc-700');
                        }
                    });
                }, 3500); 
            }

            // Pocket Logic (Single Short Card)
            const pocketContainer = document.getElementById('pocket-container');
            const pocketHint = document.getElementById('pocket-hint');
            
            if (pocketContainer) {
                pocketContainer.addEventListener('click', function(e) {
                    if (!e.target.closest('a')) {
                        this.classList.toggle('pocket-open');
                        
                        if(this.classList.contains('pocket-open')) {
                            if(pocketHint) pocketHint.style.opacity = '0';
                        } else {
                            if(pocketHint) pocketHint.style.opacity = '1';
                        }
                    }
                });
            }

            // Floating Expandable Menu Logic
            const toggleBtn = document.getElementById('floating-toggle');
            const floatingMenu = document.getElementById('floating-menu');
            const arrowIcon = document.getElementById('arrow-icon');

            if(toggleBtn && floatingMenu) {
                toggleBtn.addEventListener('click', () => {
                    floatingMenu.classList.toggle('opacity-0');
                    floatingMenu.classList.toggle('translate-y-8');
                    floatingMenu.classList.toggle('pointer-events-none');
                    
                    arrowIcon.classList.toggle('rotate-180');
                });

                document.addEventListener('click', (event) => {
                    if (!toggleBtn.contains(event.target) && !floatingMenu.contains(event.target)) {
                        floatingMenu.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
                        arrowIcon.classList.remove('rotate-180');
                    }
                });
            }

            // TESTIMONIAL MONOCHROME LOGIC
            const testiMonoCards = document.querySelectorAll('.testi-card-mono');
            const testiMonoHint = document.getElementById('testi-mono-hint');
            
            if (testiMonoCards.length > 0) {
                testiMonoCards.forEach(card => {
                    card.addEventListener('click', function(e) {
                        e.stopPropagation();
                        
                        const isActive = this.classList.contains('active-mono');

                        testiMonoCards.forEach(c => {
                            c.classList.remove('active-mono');
                        });

                        if(!isActive) {
                            this.classList.add('active-mono');
                            if(testiMonoHint) testiMonoHint.style.opacity = '0';
                            
                            this.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
                        } else {
                            if(testiMonoHint) testiMonoHint.style.opacity = '1';
                        }
                    });
                });

                document.addEventListener('click', (e) => {
                    if (!e.target.closest('.testi-card-mono')) {
                        testiMonoCards.forEach(c => c.classList.remove('active-mono'));
                        if(testiMonoHint) testiMonoHint.style.opacity = '1';
                    }
                });
            }
        });
    </script>
